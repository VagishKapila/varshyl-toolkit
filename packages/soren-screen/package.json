{
  "name": "@varshylinc/soren-screen",
  "version": "0.1.0",
  "description": "Plug-and-play Soren AI assistant screen for Varshyl products: greeting, identity cards, action grid, Q&A, portfolio builder, and voice-guided flows.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/soren-screen#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/soren-screen"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "soren",
    "ai-assistant",
    "react",
    "construction",
    "portfolio",
    "qa",
    "capacitor",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./adapters/jobsite": {
      "types": "./dist/adapters/jobsite.d.ts",
      "import": "./dist/adapters/jobsite.js",
      "require": "./dist/adapters/jobsite.cjs"
    },
    "./adapters/reference": {
      "types": "./dist/adapters/reference.d.ts",
      "import": "./dist/adapters/reference.js",
      "require": "./dist/adapters/reference.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.21.0",
    "pg": "^8.11.5",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "express": { "optional": true },
    "pg": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "express": "^4.21.0",
    "jsdom": "^24.0.0",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
