{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src/index.ts",
    "src/types.ts",
    "src/react.ts",
    "src/react/**/*",
    "src/server.ts",
    "src/server/**/*",
    "src/adapters/**/*.ts",
    "src/utils/**/*.ts"
  ]
}
