{
  "name": "@varshylinc/geo",
  "version": "0.1.0",
  "description": "Generative Engine Optimization toolkit: llms.txt, robots.txt, JSON-LD, sitemap, App Store description, React meta tags, and CLI utilities.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/geo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/geo"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "geo",
    "generative-engine-optimization",
    "llms-txt",
    "robots-txt",
    "json-ld",
    "schema-org",
    "seo",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js",
      "require": "./dist/cli/index.cjs"
    }
  },
  "bin": {
    "varshyl-geo": "./dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "react": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
