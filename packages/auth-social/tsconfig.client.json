{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["src/client/**/*", "src/client.ts", "src/types.ts", "src/config.ts", "src/types/**/*"],
  "exclude": ["node_modules", "dist"]
}
