{
  "extends": "./tsconfig.client.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/client.ts", "src/client/**/*", "src/types.ts", "src/config.ts", "src/types/**/*"]
}
