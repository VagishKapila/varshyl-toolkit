{
  "name": "@varshylinc/auth-social",
  "version": "0.4.1",
  "description": "Drop-in authentication for Capacitor + web apps: Apple, Google, and email/password sign-in with sessions, password reset, a show/hide toggle, and your own user store via an adapter.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/auth-social#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/auth-social"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "capacitor",
    "ionic",
    "authentication",
    "auth",
    "apple-sign-in",
    "google-sign-in",
    "oauth",
    "sso",
    "password-reset",
    "login",
    "react",
    "typescript",
    "mobile-auth"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "migrations",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "require": "./dist/client.js",
      "import": "./dist/client.js"
    },
    "./client/capgo": {
      "types": "./dist/client/providers/capgo-social-provider.d.ts",
      "require": "./dist/client/providers/capgo-social-provider.js",
      "import": "./dist/client/providers/capgo-social-provider.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prebuild": "tsx scripts/inline-migrations.ts && tsx scripts/inline-client-css.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.build.json && mkdir -p dist/client/components && cp src/client/components/*.css dist/client/components/",
    "pretypecheck": "tsx scripts/inline-migrations.ts && tsx scripts/inline-client-css.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "pretest": "tsx scripts/inline-migrations.ts && tsx scripts/inline-client-css.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.0",
    "jose": "^5.2.4"
  },
  "peerDependencies": {
    "pg": "^8.11.5",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
