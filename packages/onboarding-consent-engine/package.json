{
  "name": "@varshylinc/onboarding-consent-engine",
  "version": "0.3.0",
  "description": "Onboarding and legal consent for web + mobile apps: Terms/Privacy acceptance, GDPR/CCPA-style data-use consent, an audit trail, and a ready-made signup consent block.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/onboarding-consent-engine#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/onboarding-consent-engine"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "consent",
    "gdpr",
    "ccpa",
    "onboarding",
    "privacy",
    "terms-of-service",
    "consent-management",
    "ai-consent",
    "audit-trail",
    "react",
    "typescript"
  ],
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "require": "./dist/client/index.js",
      "import": "./dist/client/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "tsx scripts/inline-migrations.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.build.json",
    "pretypecheck": "tsx scripts/inline-migrations.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "pretest": "tsx scripts/inline-migrations.ts",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@types/pg": "^8.11.2",
    "@types/react": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "react": "^18.3.1",
    "@testcontainers/postgresql": "^10.28.0",
    "supertest": "^6.3.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
