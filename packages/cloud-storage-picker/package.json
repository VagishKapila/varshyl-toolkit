{
  "name": "@varshylinc/cloud-storage-picker",
  "version": "0.1.0",
  "description": "Unified cloud file picker for Varshyl products — Google Drive, Dropbox, Box, iCloud, OneDrive, device files, and manual links.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/cloud-storage-picker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/cloud-storage-picker"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "cloud-storage",
    "file-picker",
    "google-drive",
    "dropbox",
    "capacitor",
    "react",
    "typescript"
  ],
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js",
      "require": "./dist/providers.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@capawesome/capacitor-file-picker": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "@capawesome/capacitor-file-picker": { "optional": true }
  },
  "devDependencies": {
    "@capawesome/capacitor-file-picker": "^8.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
