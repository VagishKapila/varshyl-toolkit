{
  "name": "@varshylinc/notifications",
  "version": "0.1.0",
  "description": "Reusable push notification engine for Capacitor apps: device token storage, FCM/APNs send via Firebase Admin, local notification scheduling, and Hub-ready broadcast delivery reports.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/notifications#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/notifications"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "push-notifications",
    "fcm",
    "apns",
    "firebase-admin",
    "capacitor",
    "local-notifications",
    "broadcast",
    "device-tokens",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "migrations",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prebuild": "tsx scripts/inline-migrations.ts",
    "build": "tsup",
    "pretypecheck": "tsx scripts/inline-migrations.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "pretest": "tsx scripts/inline-migrations.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts --max-warnings 0"
  },
  "peerDependencies": {
    "@capacitor/core": "^6.0.0 || ^7.0.0",
    "@capacitor/local-notifications": "^6.0.0 || ^7.0.0",
    "@capacitor/push-notifications": "^6.0.0 || ^7.0.0",
    "firebase-admin": "^13.0.0",
    "pg": "^8.11.5"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": { "optional": true },
    "@capacitor/local-notifications": { "optional": true },
    "@capacitor/push-notifications": { "optional": true },
    "firebase-admin": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "firebase-admin": "^13.0.0",
    "pg": "^8.11.5",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
