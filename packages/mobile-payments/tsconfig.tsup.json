{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx"
  },
  "include": [
    "src/index.ts",
    "src/config.ts",
    "src/types.ts",
    "src/server/**/*"
  ],
  "exclude": ["node_modules", "dist", "tests", "src/client"]
}
