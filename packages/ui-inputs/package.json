{
  "name": "@varshylinc/ui-inputs",
  "version": "0.1.1",
  "description": "Drop-in React input and textarea wrappers with correct mobile keyboard defaults for every Varshyl product.",
  "author": "Vagish Kapila (Varshyl Inc.)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/VagishKapila/varshyl-toolkit/tree/main/packages/ui-inputs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/VagishKapila/varshyl-toolkit.git",
    "directory": "packages/ui-inputs"
  },
  "bugs": {
    "url": "https://github.com/VagishKapila/varshyl-toolkit/issues"
  },
  "keywords": [
    "react",
    "input",
    "textarea",
    "keyboard",
    "autocorrect",
    "capacitor",
    "mobile",
    "forms",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
