{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@varshylinc/soren-core": ["../../packages/soren-core/src/index.ts"],
      "@varshylinc/soren-react": ["../../packages/soren-react/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
