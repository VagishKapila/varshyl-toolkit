{
  "name": "@varshylinc/demo-host",
  "version": "0.0.1",
  "description": "Verification harness for varshyl-toolkit modules. NOT a product.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p client/tsconfig.client.json",
    "lint": "eslint server client/src --ext .ts,.tsx --max-warnings 0",
    "test": "echo 'demo-host has no unit tests \u2014 integration tested via QA endpoints'"
  },
  "dependencies": {
    "@varshylinc/auth-social": "workspace:*",
    "@varshylinc/onboarding-consent-engine": "workspace:*",
    "@varshylinc/team-management": "workspace:*",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.3",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
